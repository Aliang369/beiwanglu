# 后端环境变量示例
# 复制为 .env 并按需修改

# 应用
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=3000

# 数据库（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=beiwanglu

# JWT
JWT_SECRET=change-me-to-a-strong-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_SECONDS=604800  # 7 天

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 文件上传
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880  # 5MB
